# default bundles
# auto start
[submodule ".vim/pack/bundle/start/gundo"]
	path = .vim/pack/bundle/start/gundo
	url = https://github.com/sjl/gundo.vim.git
[submodule ".vim/pack/bundle/start/lightline"]
	path = .vim/pack/bundle/start/lightline
	url = https://github.com/itchyny/lightline.vim
[submodule ".vim/pack/bundle/start/vim-commentary"]
	path = .vim/pack/bundle/start/vim-commentary
	url = https://github.com/tpope/vim-commentary.git

# lsp package
# auto start
[submodule ".vim/pack/lsp/start/asyncomplete"]
	path = .vim/pack/lsp/start/asyncomplete
	url = https://github.com/prabirshrestha/asyncomplete.vim.git
[submodule ".vim/pack/lsp/start/asyncomplete-lsp"]
	path = .vim/pack/lsp/start/asyncomplete-lsp
	url = https://github.com/prabirshrestha/asyncomplete-lsp.vim.git
# lazy start
[submodule ".vim/pack/lsp/opt/async"]
	path = .vim/pack/lsp/opt/async
	url = https://github.com/prabirshrestha/async.vim.git
[submodule ".vim/pack/lsp/opt/vim-lsp"]
	path = .vim/pack/lsp/opt/vim-lsp
	url = https://github.com/prabirshrestha/vim-lsp.git
